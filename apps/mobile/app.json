{
  "expo": {
    "name": "HelvetFarm",
    "slug": "helvetfarm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "devClient": {
      "silentLaunch": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.helvetfarm.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HelvetFarm needs your location to show nearby farms on the map.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.helvetfarm.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HelvetFarm needs your location to show nearby farms on the map."
        }
      ],
      "expo-asset",
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "accessToken": ""
          },
          "ios": {
            "accessToken": ""
          }
        }
      ],
    ],
    "extra": {
      "eas": {
        "projectId": "e1d9baad-1bb1-41e5-8795-6809fe0ec513"
      }
    }
  }
}