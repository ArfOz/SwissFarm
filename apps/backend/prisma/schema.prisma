// This is your Prisma schema file
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Farm {
  id           String            @id @default(cuid())
  name         String
  lat          Float
  lng          Float
  address      String
  canton       String
  phone        String?
  website      String?
  openingHours FarmOpeningHour[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  isActive     Boolean           @default(true)

  @@index([lat, lng])
  @@index([isActive])
  @@index([isActive, lat, lng])

  types           FarmType[]
  products        FarmProduct[]
  paymentMethods  FarmPaymentMethod[]
  activities      FarmActivity[]
  suggestions     Suggestion[]

  @@map("farms")
}

model FarmType {
  farmId String
  type   String

  farm Farm @relation(fields: [farmId], references: [id])

  @@id([farmId, type])
  @@map("farm_types")
}

model ProductCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  @@map("product_categories")
}

model Product {
  id         String          @id @default(cuid())
  name       String          @unique
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  farms      FarmProduct[]

  @@map("products")
}

model FarmProduct {
  farmId    String
  productId String

  farm    Farm    @relation(fields: [farmId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@id([farmId, productId])
  @@map("farm_products")
}

model OpeningHour {
  id    String            @id @default(cuid())
  day   Weekday
  open  String? // "08:00"
  close String? // "18:00"
  farms FarmOpeningHour[]

  @@map("opening_hours")
}

model FarmOpeningHour {
  farmId        String
  openingHourId String

  farm        Farm        @relation(fields: [farmId], references: [id])
  openingHour OpeningHour @relation(fields: [openingHourId], references: [id])

  @@id([farmId, openingHourId])
  @@map("farm_opening_hours")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model PaymentMethod {
  id    String              @id @default(cuid())
  name  String              @unique
  farms FarmPaymentMethod[]

  @@map("payment_methods")
}

model FarmPaymentMethod {
  farmId          String
  paymentMethodId String

  farm           Farm           @relation(fields: [farmId], references: [id])
  paymentMethod  PaymentMethod  @relation(fields: [paymentMethodId], references: [id])

  @@id([farmId, paymentMethodId])
  @@map("farm_payment_methods")
}

model Activity {
  id    String         @id @default(cuid())
  name  String         @unique
  farms FarmActivity[]

  @@map("activities")
}

model FarmActivity {
  farmId     String
  activityId String

  farm     Farm     @relation(fields: [farmId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])

  @@id([farmId, activityId])
  @@map("farm_activities")
}

model Suggestion {
  id        String    @id @default(cuid())
  farmId    String
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  userId    String?
  author    String?
  email     String?
  message   String    @db.VarChar(1000)
  photo     String?
  status    String    @default("pending")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([farmId])
  @@index([status])
  @@index([isRead])
  @@map("suggestions")
}

enum Weekday {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}